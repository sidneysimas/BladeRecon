              {% endif %}
              {% if security_header_assets.get("assets") %}
              <div class="section-head" style="margin-top: 18px;"><h3>Security Header Assets</h3><small>CSP, CORS, and policy-derived assets</small></div>
              <div class="chips">{% for item in security_header_assets.get("assets", [])[:20] %}<span class="chip">{{ item.asset }}: {{ item.type }}</span>{% endfor %}</div>
              {% endif %}
            </div>
          </details>
        </section>

        <section class="section">
          <div class="section-head">
            <h2>Severity Dashboard</h2>
            <small>{% if nuclei_skipped_reason %}Nuclei scan status{% else %}{{ nuclei_count }} total findings{% endif %}</small>
          </div>
          {% if nuclei_skipped_reason %}
          <div class="card status-card">
            <span class="badge medium">Nuclei Status</span>
            <span class="metric-number status-number">Skipped</span>
            <span class="metric-label">Reason: {{ nuclei_skipped_reason }}</span>
          </div>
          {% else %}
          <div class="severity-chart" aria-label="Severity distribution chart">
            <div class="severity-track">
              {% for sev in ["critical", "high", "medium", "low", "info"] %}
              <span class="severity-segment {{ sev }}" data-severity-count="{{ nuclei_severity_counts.get(sev, 0) }}" title="{{ sev | title }}: {{ nuclei_severity_counts.get(sev, 0) }}"></span>
              {% endfor %}
            </div>
            <div class="severity-legend">
              {% for sev in ["critical", "high", "medium", "low", "info"] %}
              <span class="chip"><span class="legend-dot" style="background: var(--{{ sev }});"></span>{{ sev | title }}: {{ nuclei_severity_counts.get(sev, 0) }}</span>
              {% endfor %}
            </div>
          </div>
          <div class="grid severity-grid">
            {% for sev in ["critical", "high", "medium", "low", "info"] %}
            <div class="card severity {{ sev }}">
              <span class="metric-number">{{ nuclei_severity_counts.get(sev, 0) }}</span>
              <span class="metric-label">{{ sev | title }}</span>
            </div>
            {% endfor %}
          </div>
          {% if nuclei_metadata %}
          <div class="grid intel-grid">
            <div class="intel-item"><span class="intel-value">{{ nuclei_metadata.get("coverage_status", "completed" if nuclei_metadata.get("status") == "completed" else nuclei_metadata.get("status", "Not recorded")) }}</span><span class="intel-label">Coverage Status</span></div>
            <div class="intel-item"><span class="intel-value">{{ nuclei_metadata.get("templates_executed") if nuclei_metadata.get("templates_executed") is not none else "Incomplete" }}</span><span class="intel-label">Templates Executed</span></div>
            <div class="intel-item"><span class="intel-value">{{ nuclei_metadata.get("templates_skipped") if nuclei_metadata.get("templates_skipped") is not none else "Incomplete" }}</span><span class="intel-label">Templates Skipped</span></div>
            <div class="intel-item"><span class="intel-value">{{ nuclei_metadata.get("duration_seconds", "Not recorded") }}s</span><span class="intel-label">Nuclei Duration</span></div>
            <div class="intel-item"><span class="intel-value">{{ nuclei_metadata.get("findings_count", nuclei_count) }}</span><span class="intel-label">Findings Count</span></div>
          </div>
          {% if nuclei_metadata.get("status") == "timed_out" or nuclei_metadata.get("coverage_status") == "incomplete_timeout" %}
          <div class="note" style="margin-top: 12px;">Nuclei timed out after {{ nuclei_metadata.get("timeout_seconds", "the configured timeout") }}s. Coverage is incomplete, so zero findings should not be interpreted as clean validation.</div>
          {% endif %}
          {% if nuclei_metadata.get("baseline_scan") %}
          <div class="note" style="margin-top: 12px;">Coverage strategy: {{ nuclei_metadata.get("coverage_strategy", "profile/default") }}. Baseline safety net: {{ nuclei_metadata.get("baseline_scan", {}).get("status", "not_applicable") }}{% if nuclei_metadata.get("baseline_scan", {}).get("applied") %}, severity {{ nuclei_metadata.get("baseline_scan", {}).get("severity") }}{% endif %}.</div>
          {% endif %}
          {% endif %}
          {% endif %}
        </section>

        <section class="section" id="data-panels">
          <details class="data-panel" id="subdomains">
            <summary><span class="summary-title"><strong>Subdomains</strong><small>Preview first 20 rows. Expand for full list.</small></span><span class="summary-count">{{ subdomains | length }}</span></summary>
            <div class="panel-body" data-panel="subdomains"></div>
          </details>

          <details class="data-panel" id="javascript">
            <summary><span class="summary-title"><strong>JavaScript Files</strong><small>Preview first 20 rows. Expand for full list.</small></span><span class="summary-count">{{ js_files | length }}</span></summary>
            <div class="panel-body" data-panel="javascript"></div>
          </details>

          <details class="data-panel" id="endpoints">
            <summary><span class="summary-title"><strong>Endpoints</strong><small>Preview first 20 rows. Expand for full list.</small></span><span class="summary-count">{{ endpoints | length }}</span></summary>
            <div class="panel-body" data-panel="endpoints"></div>
          </details>

          <details class="data-panel" id="parameters">
            <summary><span class="summary-title"><strong>Parameters</strong><small>{% if parameters_skipped_reason %}Skipped: {{ parameters_skipped_reason }}{% else %}Preview first 20 rows. Expand for full list.{% endif %}</small></span><span class="summary-count">{{ parameters_status }}</span></summary>
            <div class="panel-body" data-panel="parameters"></div>
          </details>

          <details class="data-panel" id="secrets">
            <summary><span class="summary-title"><strong>Secrets</strong><small>Preview first 20 rows. Expand for full list.</small></span><span class="summary-count">{{ secrets | length }}</span></summary>
            <div class="panel-body" data-panel="secrets"></div>
          </details>

          <details class="data-panel" id="screenshots">
            <summary><span class="summary-title"><strong>Screenshots</strong><small>{% if screenshots_skipped_reason %}Skipped: {{ screenshots_skipped_reason }}{% else %}Preview first 20 captures. Expand for gallery.{% endif %}</small></span><span class="summary-count">{{ screenshots_status }}</span></summary>
            <div class="panel-body" data-panel="screenshots"></div>
          </details>

          <details class="data-panel" id="findings">
            <summary><span class="summary-title"><strong>Nuclei Findings</strong><small>{% if nuclei_skipped_reason %}{{ nuclei_status_label }}: {{ nuclei_skipped_reason }}{% else %}Preview first 20 findings. Expand for full list.{% endif %}</small></span><span class="summary-count">{{ nuclei_status }}</span></summary>
            <div class="panel-body" data-panel="findings"></div>
          </details>
        </section>

        <section class="section" id="performance">
          <details class="data-panel">
            <summary><span class="summary-title"><strong>Performance Analytics</strong><small>Scan timing, requests, and slowest modules.</small></span><span class="summary-count">{{ performance.total_duration }}</span></summary>
            <div class="panel-body">
              <div class="intel-grid">
                <div class="intel-item"><span class="intel-value">{{ performance.total_duration }}</span><span class="intel-label">Total Duration</span></div>
                <div class="intel-item" title="{{ performance.traffic_note }}"><span class="intel-value">{{ performance.total_requests_sent }}</span><span class="intel-label">Estimated Requests Attempted</span></div>
                <div class="intel-item" title="{{ performance.traffic_note }}"><span class="intel-value">{{ performance.total_responses_received }}</span><span class="intel-label">HTTP Responses Recorded</span></div>
                <div class="intel-item"><span class="intel-value">{{ performance.module_count }}</span><span class="intel-label">Module Count</span></div>
              </div>
              <p class="muted">{{ performance.traffic_note }}</p>
              {% if performance.top_slowest_modules or performance.top_ram_consumers %}
              <div class="ranking-grid">
                <div class="ranking-card">
                  <span class="label">Top Slowest Modules</span>
                  <ol class="ranking-list">
                    {% for row in performance.top_slowest_modules %}
                    <li><span><span class="rank-index">{{ loop.index }}.</span> {{ row.module }}</span><strong>{{ row.duration_seconds }}s</strong></li>
                    {% else %}
                    <li>No completed module timing recorded</li>
                    {% endfor %}
                  </ol>
                </div>
                <div class="ranking-card">
                  <span class="label">Top RAM Consumers</span>
                  <ol class="ranking-list">
                    {% for row in performance.top_ram_consumers %}
                    <li><span><span class="rank-index">{{ loop.index }}.</span> {{ row.module }}</span><strong>{{ row.peak_ram_mb }} MB</strong></li>
                    {% else %}
                    <li>No module memory data recorded</li>
                    {% endfor %}
                  </ol>
                </div>
              </div>
              {% endif %}
              <div class="section-head" style="margin-top: 18px;"><h3>Module Performance</h3><small>Detailed timing and memory samples</small></div>
              <div class="table-wrap">
                <table>
                  <thead><tr><th>Module</th><th>Status</th><th>Duration</th><th>Peak RAM</th><th>Average RAM</th></tr></thead>
                  <tbody>
                    {% for row in performance.modules %}
                    <tr><td>{{ row.module }}</td><td>{{ row.status }}</td><td>{{ row.duration_seconds }}s</td><td>{{ row.peak_ram_mb }} MB</td><td>{{ row.average_ram_mb }} MB</td></tr>
                    {% endfor %}
                  </tbody>
                </table>
              </div>
            </div>
          </details>
        </section>

        <footer class="footer">
          <div>Generated by BladeRecon v{{ version }}</div>
          <div>Developed by Mohamed Kotb &middot; github.com/mohamedxk9tb</div>
        </footer>
      </main>
    </div>

    <div class="lightbox" id="screenshotLightbox" aria-hidden="true">
      <button class="btn" type="button" data-lightbox-close>Close</button>
      <img src="" alt="Expanded screenshot">
    </div>

    <script>
      const PREVIEW_LIMIT = 20;
      const data = {
        target: {{ target | tojson }},
        subdomains: [
          {% for s in subdomains %}
          {subdomain: {{ s | tojson }}, status: {{ ("Alive" if s in alive_hostnames else "Passive") | tojson }}, sources: {{ subdomain_sources.get(s, ["Passive"]) | tojson }} }{% if not loop.last %},{% endif %}
          {% endfor %}
        ],
        jsFiles: {{ js_files | tojson }},
        endpoints: {{ endpoints | tojson }},
        parameters: {{ parameters | tojson }},
        parameterIntel: {{ parameter_intelligence | tojson }},
        parametersSkippedReason: {{ parameters_skipped_reason | tojson }},
        secrets: {{ secrets | tojson }},
        screenshots: {{ screenshots | tojson }},
        screenshotFailures: {{ screenshot_failures | tojson }},
        nuclei: {{ nuclei | tojson }},
        nucleiAvailable: {{ nuclei_available | tojson }},
        screenshotsAvailable: {{ screenshots_available | tojson }},
        nucleiSkippedReason: {{ nuclei_skipped_reason | tojson }},
        screenshotsSkippedReason: {{ screenshots_skipped_reason | tojson }}
      };
      const discoveredParameterSet = new Set((data.parameterIntel.discovered || []).map((item) => String(item).toLowerCase()));

      const escapeHtml = (value) => String(value ?? '')
        .replaceAll('&', '&amp;')
        .replaceAll('<', '&lt;')
        .replaceAll('>', '&gt;')
        .replaceAll('"', '&quot;')
        .replaceAll("'", '&#039;');

      const categoryBadge = (label, cls = 'info') => `<span class="badge ${cls}">${escapeHtml(label)}</span>`;
      const code = (value) => `<code>${escapeHtml(value)}</code>`;

      function parameterCategory(name) {
        const value = String(name || '').toLowerCase();
        if (/(auth|token|session|jwt|key|password|secret|csrf)/.test(value)) return 'Authentication';
        if (/(redirect|url|next|return|callback)/.test(value)) return 'Redirect';
        if (/(page|limit|offset|cursor|sort|order)/.test(value)) return 'Pagination';
        if (/(file|path|upload|download|image|media)/.test(value)) return 'Files';
        if (/(api|endpoint|graphql|rest)/.test(value)) return 'API';
        if (/(q|query|search|keyword|term)/.test(value)) return 'Search';
        return 'General';
      }

      function parameterValueLevel(name) {
        const value = String(name || '').toLowerCase();
        const high = ['access_token', 'refresh_token', 'api_key', 'authorization', 'token', 'jwt', 'secret', 'session', 'auth', 'key'];
        const medium = ['account_id', 'return_url', 'user_id', 'redirect', 'callback', 'email', 'username', 'id'];
        const low = ['filter', 'page', 'sort', 'lang', 'theme', 'view', 'tab'];
        if (high.some((item) => value === item || value.includes(item))) return 'High';
        if (medium.some((item) => value === item || value.includes(item))) return 'Medium';
        if (low.some((item) => value === item || value.includes(item))) return 'Low';
        return 'Low';
      }

      function parameterSource(name) {
        return discoveredParameterSet.has(String(name || '').toLowerCase()) ? 'Discovered' : 'Candidate';
      }

      function subdomainCategory(host) {
        const value = String(host || '').toLowerCase();
        if (/(^|[.-])api[.-]/.test(value) || value.includes('graphql') || value.includes('rest')) return 'API';
        if (/(admin|panel|console|dashboard|cpanel|manager)/.test(value)) return 'Admin';
        if (/(dev|stage|staging|test|qa|uat|beta|sandbox)/.test(value)) return 'Development';
        if (/(mail|smtp|imap|mx|webmail)/.test(value)) return 'Mail';
        return 'General';
      }

      function summarize(items, keyFn) {
        const counts = {};
        items.forEach((item) => {
          const key = keyFn(item);
          counts[key] = (counts[key] || 0) + 1;
        });
        return Object.entries(counts).sort((a, b) => b[1] - a[1]);
      }

      function summaryChips(entries) {
        if (!entries.length) return '';
        return `<div class="category-row">${entries.map(([label, count]) => `<span class="chip">${escapeHtml(label)}: ${count}</span>`).join('')}</div>`;
      }

      function endpointIntelCategory(item) {
        const value = String(item.endpoint || '').toLowerCase();
        const raw = String(item.category || '').toLowerCase();
        if (raw.includes('graphql') || value.includes('graphql')) return 'GraphQL';
        if (raw.includes('swagger') || raw.includes('openapi') || /(swagger|openapi|api-docs)/.test(value)) return 'Swagger/OpenAPI';
        if (raw.includes('websocket') || value.startsWith('ws://') || value.startsWith('wss://') || value.includes('socket.io')) return 'WebSocket';
        if (/(auth|login|logout|register|oauth|sso|session)/.test(value)) return 'Authentication';
        if (/(admin|panel|console|dashboard|manage)/.test(value)) return 'Admin';
        if (/(\/api\/|\/api$|\/v[0-9]+\/|\/rest)/.test(value)) return 'REST APIs';
        return 'Other';
      }

      function filterItems(items, query, textFn) {
        if (!query) return items;
        const needle = query.toLowerCase();
        return items.filter((item) => textFn(item).toLowerCase().includes(needle));
      }

      function table(headers, rows) {
        if (!rows.length) return `<div class="empty">No matching data</div>`;
        return `<div class="table-wrap"><table><thead><tr>${headers.map((h) => `<th>${escapeHtml(h)}</th>`).join('')}</tr></thead><tbody>${rows.join('')}</tbody></table></div>`;
      }

      function panelScaffold(name, total, exportLinks = '') {
        return `
          <div class="panel-tools">
            <input class="search section-search" data-search-panel="${name}" type="search" placeholder="Search ${name}">
            <div class="actions">${exportLinks}</div>
          </div>
          <div class="muted panel-count" data-count-panel="${name}">Showing ${Math.min(PREVIEW_LIMIT, total)} of ${total}</div>
          <div data-summary-panel="${name}"></div>
          <div data-table-panel="${name}"></div>
        `;
      }

      const renderers = {
        subdomains(full = false, query = '') {
          const items = filterItems(data.subdomains, query, (item) => `${item.subdomain} ${item.status} ${item.sources.join(' ')} ${subdomainCategory(item.subdomain)}`);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const rows = visible.map((item) => `<tr><td>${code(item.subdomain)}</td><td>${categoryBadge(item.status, item.status === 'Alive' ? 'alive' : 'passive')}</td><td>${item.sources.map((s) => categoryBadge(s)).join('')}</td></tr>`);
          return {
            count: `Showing ${visible.length} of ${items.length} Subdomains`,
            summary: summaryChips(summarize(data.subdomains, (item) => subdomainCategory(item.subdomain))),
            table: table(['Subdomain', 'Status', 'Source'], rows)
          };
        },
        javascript(full = false, query = '') {
          const items = filterItems(data.jsFiles, query, (item) => `${item.url || ''} ${item.source_page || ''}`);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const rows = visible.map((item) => `<tr><td>${code(item.url || '')}</td><td>${code(item.source_page || '')}</td></tr>`);
          return {
            count: `Showing ${visible.length} of ${items.length} JavaScript Files`,
            summary: summaryChips(summarize(data.jsFiles, (item) => {
              const path = String(item.url || '').toLowerCase();
              if (path.includes('chunk')) return 'Chunks';
              if (path.includes('vendor')) return 'Vendor';
              if (path.includes('bundle')) return 'Bundles';
              return 'Assets';
            })),
            table: table(['URL', 'Source Page'], rows)
          };
        },
        endpoints(full = false, query = '') {
          const items = filterItems(data.endpoints, query, (item) => `${item.endpoint || ''} ${endpointIntelCategory(item)} ${item.source_js_file || item.source || ''}`);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const rows = visible.map((item) => `<tr><td>${code(item.endpoint || '')}</td><td>${categoryBadge(endpointIntelCategory(item))}</td><td>${code(item.source_js_file || item.source || '')}</td></tr>`);
          return {
            count: `Showing ${visible.length} of ${items.length} Endpoints`,
            summary: summaryChips(summarize(data.endpoints, endpointIntelCategory)),
            table: table(['Endpoint', 'Category', 'Source'], rows)
          };
        },
        parameters(full = false, query = '') {
          if (data.parametersSkippedReason) {
            return {count: `Parameters: Skipped (${data.parametersSkippedReason})`, summary: '', table: `<div class="empty">Parameters: Skipped (${escapeHtml(data.parametersSkippedReason)})</div>`};
          }
          const intel = data.parameterIntel || {};
          const items = filterItems(data.parameters, query, (item) => `${item} ${parameterCategory(item)} ${parameterValueLevel(item)} ${parameterSource(item)}`);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const rows = visible.map((item) => {
            const category = parameterCategory(item);
            const source = parameterSource(item);
            const level = parameterValueLevel(item);
            const categoryCls = category === 'Authentication' ? 'high' : category === 'Files' ? 'medium' : category === 'Redirect' ? 'info' : 'passive';
            const levelCls = level === 'High' ? 'high' : level === 'Medium' ? 'medium' : 'low';
            return `<tr><td>${code(item)}</td><td>${categoryBadge(source, source === 'Discovered' ? 'alive' : 'passive')}</td><td>${categoryBadge(level, levelCls)}</td><td>${categoryBadge(category, categoryCls)}</td></tr>`;
          });
          const intelligence = summaryChips([
            ['Discovered Parameters', intel.discovered_count || 0],
            ['Candidate Parameters', intel.candidate_count || 0],
            ['Total Parameters', intel.total_count || 0],
            ['High Value Parameters', intel.high_count || 0],
            ['Medium Value Parameters', intel.medium_count || 0],
            ['Low Value Parameters', intel.low_count || 0]
          ]);
          return {
            count: `Showing ${visible.length} of ${items.length} Parameters`,
            summary: intelligence + summaryChips(summarize(data.parameters, parameterCategory)),
            table: table(['Parameter', 'Source', 'Value', 'Risk Category'], rows)
          };
        },
        secrets(full = false, query = '') {
          const items = filterItems(data.secrets, query, (item) => `${item.type || ''} ${item.confidence || ''} ${item.risk || ''} ${item.value_preview || ''} ${item.value_fingerprint || ''} ${item.source || ''}`);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const rows = visible.map((item) => {
            const confidence = String(item.confidence || 'LOW').toUpperCase();
            const cls = confidence === 'HIGH' ? 'high' : confidence === 'MEDIUM' ? 'medium' : 'low';
            return `<tr><td>${categoryBadge(item.type || 'Secret', cls)}</td><td>${categoryBadge(confidence, cls)}</td><td>${code(item.source || '')}</td><td>${code(item.value_preview || '[redacted]')}</td><td>${categoryBadge(item.risk || 'Low', cls)}</td></tr>`;
          });
          return {
            count: `Showing ${visible.length} of ${items.length} Secrets`,
            summary: summaryChips(summarize(data.secrets, (item) => String(item.confidence || 'LOW').toUpperCase())),
            table: table(['Secret Type', 'Confidence', 'Source File', 'Value Preview', 'Risk Level'], rows)
          };
        },
        screenshots(full = false, query = '') {
          if (data.screenshotsSkippedReason) {
            return {count: `Screenshots: Skipped (${data.screenshotsSkippedReason})`, summary: '', table: `<div class="empty">Screenshots: Skipped (${escapeHtml(data.screenshotsSkippedReason)})<br><br><code>python -m playwright install chromium</code></div>`};
          }
          const items = filterItems(data.screenshots, query, (item) => item);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const failures = data.screenshotFailures || [];
          const failureSummary = failures.length
            ? summaryChips(summarize(failures, (item) => item.reason || 'Screenshot failed'))
            : '';
          const gallery = visible.length
            ? `<div class="shot-grid">${visible.map((img) => `<article class="card shot-card"><a href="${escapeHtml(img)}" data-lightbox-image="${escapeHtml(img)}"><img src="${escapeHtml(img)}" loading="lazy" alt="${escapeHtml(img)}" onerror="this.closest('.shot-card').classList.add('image-error')"></a><div class="shot-body"><div class="shot-title">${escapeHtml(img)}</div><p><a class="btn" href="${escapeHtml(img)}">Open Full Size</a></p></div></article>`).join('')}</div>`
            : `<div class="empty">No screenshots captured</div>`;
          const failedList = failures.length
            ? `<div class="failed-shot-list">${failures.map((item) => `<div class="failed-shot"><code>${escapeHtml(item.url || item.host || 'unknown target')}</code>${categoryBadge(item.reason || 'Capture failed', 'medium')}</div>`).join('')}</div>`
            : '';
          return {count: `Showing ${visible.length} of ${items.length} Screenshots`, summary: failureSummary, table: gallery + failedList};
        },
        findings(full = false, query = '') {
          if (data.nucleiSkippedReason) {
            return {count: `Nuclei: {{ nuclei_status_label }} (${data.nucleiSkippedReason})`, summary: '', table: `<div class="empty">Nuclei: {{ nuclei_status_label }} (${escapeHtml(data.nucleiSkippedReason)})</div>`};
          }
          const flat = Object.entries(data.nuclei || {}).flatMap(([severity, items]) => (items || []).map((item) => ({severity, item})));
          const items = filterItems(flat, query, (row) => `${row.severity} ${row.item?.info?.name || row.item?.template || ''} ${row.item?.host || row.item?.matched || row.item?.['matched-at'] || ''} ${row.item?.info?.description || ''}`);
          const visible = full || query ? items : items.slice(0, PREVIEW_LIMIT);
          const cards = visible.map((row) => {
            const item = row.item || {};
            const info = item.info || {};
            const title = info.name || item.template || 'Unnamed finding';
            const host = item.host || item.matched || item['matched-at'] || 'unknown host';
            const template = item.template || item['template-id'] || 'Not recorded';
            const description = info.description || item.description || 'No description provided.';
            const evidence = item['extracted-results'] || item['matcher-name'] || item['curl-command'] || item.ip || item.type || '';
            const refs = Array.isArray(info.reference) ? info.reference : (info.reference ? [info.reference] : []);
            return `
              <article class="finding-card ${escapeHtml(row.severity)}">
                <div class="finding-head">
                  <div>
                    <div class="finding-title">${escapeHtml(title)}</div>
                    <div class="muted">${escapeHtml(description)}</div>
                  </div>
                  ${categoryBadge(row.severity, row.severity)}
                </div>
                <div class="finding-grid">
                  <div><span class="label">Host</span><div>${code(host)}</div></div>
                  <div><span class="label">Template</span><div>${code(template)}</div></div>
                </div>
                <div class="finding-evidence"><span class="label">Evidence</span><div>${evidence ? code(Array.isArray(evidence) ? evidence.join(', ') : evidence) : '<span class="muted">No extracted evidence recorded</span>'}</div></div>
                ${refs.length ? `<div><span class="label">References</span><ul class="reference-list">${refs.slice(0, 4).map((ref) => `<li><a href="${escapeHtml(ref)}">${escapeHtml(ref)}</a></li>`).join('')}</ul></div>` : ''}
              </article>
            `;
          });
          return {
            count: `Showing ${visible.length} of ${items.length} Findings`,
            summary: summaryChips(summarize(flat, (row) => row.severity || 'unknown')),
            table: cards.length ? `<div class="finding-list">${cards.join('')}</div>` : `<div class="empty">No matching findings</div>`
          };
        }
      };

      const exportsByPanel = {
        subdomains: `<a class="btn" href="../subdomains/subdomains.txt">Export Subdomains</a><a class="btn" href="../subdomains/subdomains.json">JSON</a>`,
        javascript: `<a class="btn" href="../js/js_files.txt">Export JS Files</a><a class="btn" href="../js/js_files.json">JSON</a>`,
        endpoints: `<a class="btn" href="../endpoints/endpoints.txt">Export Endpoints</a><a class="btn" href="../endpoints/endpoints.json">JSON</a>`,
        parameters: data.parametersSkippedReason ? '' : `<a class="btn" href="../parameters/parameters.txt">Export Parameters</a><a class="btn" href="../parameters/parameters.json">JSON</a>`,
        secrets: `<a class="btn" href="../secrets/secrets.txt">Export Redacted Secrets</a>`
      };

      function renderPanel(name, full = false, query = '') {
        const body = document.querySelector(`[data-panel="${name}"]`);
        if (!body) return;
        if (!body.dataset.ready) {
          const totals = {
            subdomains: data.subdomains.length,
            javascript: data.jsFiles.length,
            endpoints: data.endpoints.length,
            parameters: data.parameters.length,
            secrets: data.secrets.length,
            screenshots: data.screenshots.length,
            findings: Object.values(data.nuclei || {}).reduce((sum, items) => sum + (items || []).length, 0)
          };
          body.innerHTML = panelScaffold(name, totals[name] || 0, exportsByPanel[name] || '');
          body.dataset.ready = '1';
          body.querySelector('.section-search')?.addEventListener('input', (event) => renderPanel(name, true, event.target.value.trim()));
        }
        const result = renderers[name](full, query);
        body.querySelector(`[data-count-panel="${name}"]`).textContent = result.count;
        body.querySelector(`[data-summary-panel="${name}"]`).innerHTML = result.summary;
        body.querySelector(`[data-table-panel="${name}"]`).innerHTML = result.table;
        if (name === 'screenshots') wireLightbox(body);
      }

      function updateSeverityChart() {
        const segments = [...document.querySelectorAll('.severity-segment')];
        const total = segments.reduce((sum, item) => sum + Number(item.dataset.severityCount || 0), 0);
        segments.forEach((item) => {
          const count = Number(item.dataset.severityCount || 0);
          item.style.width = total ? `${Math.max((count / total) * 100, count ? 2 : 0)}%` : '0%';
        });
      }

      function wireLightbox(scope = document) {
        const box = document.getElementById('screenshotLightbox');
        const img = box?.querySelector('img');
        if (!box || !img) return;
        scope.querySelectorAll('[data-lightbox-image]').forEach((link) => {
          if (link.dataset.boundLightbox) return;
          link.dataset.boundLightbox = '1';
          link.addEventListener('click', (event) => {
            event.preventDefault();
            img.src = link.dataset.lightboxImage || link.getAttribute('href');
            box.classList.add('open');
            box.setAttribute('aria-hidden', 'false');
          });
        });
      }

      document.querySelector('[data-lightbox-close]')?.addEventListener('click', () => {
        const box = document.getElementById('screenshotLightbox');
        if (!box) return;
        box.classList.remove('open');
        box.setAttribute('aria-hidden', 'true');
      });
      document.getElementById('screenshotLightbox')?.addEventListener('click', (event) => {
        if (event.target.id === 'screenshotLightbox') {
          event.currentTarget.classList.remove('open');
          event.currentTarget.setAttribute('aria-hidden', 'true');
        }
      });
      updateSeverityChart();

      document.querySelectorAll('.data-panel').forEach((panel) => {
        const name = panel.querySelector('.panel-body')?.dataset.panel;
        panel.addEventListener('toggle', () => {
          if (panel.open && name) renderPanel(name, true);
        });
        if (name) renderPanel(name, false);
      });

      document.getElementById('copySummary')?.addEventListener('click', async () => {
        const summary = [
          'BladeRecon Report',
          `Target: ${data.target}`,
          `Subdomains: ${data.subdomains.length}`,
          'Alive Hosts: {{ alive_count }}',
          `JavaScript Files: ${data.jsFiles.length}`,
          `Endpoints: ${data.endpoints.length}`,
          `Secrets: ${data.secrets.length}`,
          'Parameters: {{ parameters_status }}',
          'Screenshots: {{ screenshots_status }}',
          'Findings: {{ nuclei_status }}'
        ].join('\n');
        try {
          await navigator.clipboard.writeText(summary);
        } catch {
          const area = document.createElement('textarea');
          area.value = summary;
          document.body.appendChild(area);
          area.select();
          document.execCommand('copy');
          area.remove();
        }
      });

      const navLinks = [...document.querySelectorAll('.nav a')];
      const sections = navLinks
        .map((link) => document.querySelector(link.getAttribute('href')))
        .filter(Boolean);
      const setActive = () => {
        let current = sections[0]?.id || 'overview';
        sections.forEach((section) => {
          if (section.getBoundingClientRect().top <= 120) current = section.id;
        });
        navLinks.forEach((link) => link.classList.toggle('active', link.getAttribute('href') === `#${current}`));
      };
      setActive();
      document.addEventListener('scroll', setActive, {passive: true});
    </script>
  </body>
</html>
