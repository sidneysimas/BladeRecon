<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>BladeRecon Report - {{ target }}</title>
    <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='12' fill='%230f172a'/%3E%3Cpath d='M18 48 45 15l-7 27-20 6Z' fill='%2306b6d4'/%3E%3C/svg%3E">
    <style>
      :root {
        --bg: #090d14;
        --panel: #111827;
        --panel-2: #0f172a;
        --border: #253044;
        --accent: #22d3ee;
        --accent-2: #38bdf8;
        --success: #22c55e;
        --warning: #f59e0b;
        --critical: #f87171;
        --high: #fb923c;
        --medium: #facc15;
        --low: #4ade80;
        --info: #38bdf8;
        --text: #e5edf7;
        --muted: #94a3b8;
        --shadow: 0 18px 40px rgba(0, 0, 0, .35);
        --radius: 8px;
      }
      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        background: radial-gradient(circle at top left, rgba(34, 211, 238, .10), transparent 28rem), linear-gradient(180deg, #0b1220 0%, var(--bg) 24rem);
        color: var(--text);
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        line-height: 1.5;
      }
      a { color: inherit; }
      code { color: #7dd3fc; font-family: "SFMono-Regular", Consolas, "Liberation Mono", monospace; overflow-wrap: anywhere; }
      .layout { display: grid; grid-template-columns: 220px minmax(0, 1fr); gap: 22px; width: min(1460px, calc(100% - 40px)); margin: 0 auto; padding: 28px 0 36px; }
      .sidebar { position: sticky; top: 18px; align-self: start; padding: 16px; border: 1px solid var(--border); border-radius: var(--radius); background: rgba(17,24,39,.92); box-shadow: 0 12px 28px rgba(0,0,0,.28); }
      .side-brand { color: var(--accent); font-weight: 850; margin-bottom: 14px; }
      .nav { display: grid; gap: 6px; }
      .nav a { text-decoration: none; color: var(--muted); padding: 8px 10px; border-radius: 10px; display: flex; align-items: center; gap: 8px; border: 1px solid transparent; }
      .nav a:hover, .nav a.active { color: var(--text); background: rgba(15,118,110,.08); border-color: rgba(15,118,110,.22); }
      .nav-icon { width: 1.15rem; text-align: center; color: var(--accent); }
      .main { min-width: 0; }
      .hero {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 24px;
        align-items: stretch;
        padding: 28px;
        border: 1px solid var(--border);
        border-radius: 12px;
        background: linear-gradient(135deg, #111827, #0f172a);
        box-shadow: var(--shadow);
      }
      .brand { display: flex; align-items: center; gap: 12px; color: var(--accent); font-weight: 800; letter-spacing: .02em; }
      .logo { width: 42px; height: 42px; display: grid; place-items: center; border: 1px solid rgba(34,211,238,.32); border-radius: 10px; background: rgba(34,211,238,.10); font-size: 1.35rem; }
      .logo img { width: 100%; height: 100%; object-fit: contain; display: block; border-radius: 10px; }
      .hero h1 { margin: 16px 0 8px; font-size: clamp(2rem, 4vw, 3.5rem); line-height: 1.02; letter-spacing: 0; }
      .hero p { margin: 0; color: var(--muted); font-size: 1.02rem; }
      .hero-meta { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 18px; }
      .hero-pill { border: 1px solid var(--border); border-radius: 999px; background: var(--panel); color: var(--muted); padding: 7px 10px; font-size: .82rem; font-weight: 700; }
      .hero-pill strong { color: var(--text); }
      .risk-panel { min-width: 310px; display: grid; gap: 12px; align-content: start; padding: 18px; border: 1px solid rgba(34,211,238,.22); border-radius: 10px; background: #0b1220; color: #f8fafc; }
      .risk-panel .label, .risk-panel .muted { color: #cbd5e1; }
      .risk-score { display: flex; align-items: end; justify-content: space-between; gap: 16px; }
      .risk-score strong { font-size: 3.2rem; line-height: .9; letter-spacing: 0; }
      .risk-level { border-radius: 999px; padding: 6px 10px; font-size: .8rem; font-weight: 800; background: rgba(255,255,255,.12); color: #fff; }
      .risk-panel-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
      .risk-mini { padding: 10px; border: 1px solid rgba(255,255,255,.14); border-radius: 8px; background: rgba(255,255,255,.06); }
      .risk-mini .value { color: #fff; }
      .meta-grid { display: grid; grid-template-columns: repeat(2, minmax(130px, 1fr)); gap: 10px; min-width: 320px; }
      .meta-card, .card, .data-panel {
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: var(--radius);
        box-shadow: 0 10px 24px rgba(0, 0, 0, .22);
      }
      .meta-card { padding: 14px; }
      .label { color: var(--muted); font-size: .78rem; text-transform: uppercase; letter-spacing: .08em; }
      .value { margin-top: 4px; font-weight: 700; word-break: break-word; }
      .toolbar { display: flex; flex-wrap: wrap; gap: 12px; justify-content: space-between; align-items: center; margin: 22px 0; }
      .actions { display: flex; flex-wrap: wrap; gap: 10px; }
      .btn {
        border: 1px solid rgba(34,211,238,.30);
        background: rgba(34,211,238,.10);
        color: var(--text);
        border-radius: 8px;
        padding: 10px 12px;
        font-weight: 700;
        text-decoration: none;
        cursor: pointer;
      }
      .btn:hover { border-color: var(--accent); transform: translateY(-1px); }
      .grid { display: grid; gap: 16px; }
      .kpis { grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); align-items: stretch; }
      .surface { grid-template-columns: repeat(5, minmax(0, 1fr)); }
      .card { padding: 18px; transition: transform .18s ease, box-shadow .18s ease, border-color .18s ease; }
      .kpi-card { min-height: 118px; display: flex; flex-direction: column; justify-content: space-between; }
      .card:hover { transform: translateY(-2px); border-color: rgba(15,118,110,.28); box-shadow: var(--shadow); }
      .metric-icon { color: var(--accent); font-size: 1.25rem; }
      .metric-number { display: block; margin-top: 10px; font-size: 2rem; line-height: 1; font-weight: 850; letter-spacing: -.03em; overflow-wrap: anywhere; }
      .status-number { font-size: 1.15rem; letter-spacing: 0; }
      .metric-label { color: var(--muted); font-size: .9rem; }
      .metric-note { color: var(--muted); font-size: .72rem; margin-top: 6px; min-height: 1em; }
      .note { color: var(--muted); font-size: .86rem; line-height: 1.35; }
      .section { margin-top: 22px; scroll-margin-top: 18px; }
      .section-head { display: flex; justify-content: space-between; align-items: end; gap: 12px; margin-bottom: 12px; }
      h2 { margin: 0; font-size: 1.15rem; }
      small, .muted { color: var(--muted); }
      .chips { display: flex; flex-wrap: wrap; gap: 8px; }
      .chip, .badge {
        display: inline-flex; align-items: center; gap: 6px;
        border-radius: 999px; padding: 5px 9px;
        border: 1px solid rgba(148, 163, 184, .2);
        background: rgba(15,23,42,.86);
        color: var(--text);
        font-size: .78rem; font-weight: 700;
      }
      .badge.alive, .badge.low { color: var(--low); border-color: rgba(34, 197, 94, .28); background: rgba(34, 197, 94, .09); }
      .badge.passive, .badge.info { color: var(--info); border-color: rgba(56, 189, 248, .28); background: rgba(56, 189, 248, .09); }
      .badge.critical { color: var(--critical); border-color: rgba(239, 68, 68, .32); background: rgba(239, 68, 68, .1); }
      .badge.high { color: var(--high); border-color: rgba(249, 115, 22, .32); background: rgba(249, 115, 22, .1); }
      .badge.medium { color: var(--medium); border-color: rgba(234, 179, 8, .32); background: rgba(234, 179, 8, .1); }
      .summary-card ul { margin: 12px 0 0; padding-left: 20px; color: var(--muted); }
      .summary-card li { margin: 5px 0; }
      .summary-card strong { color: var(--text); }
      .executive-card { border-top: 3px solid var(--accent); }
      .executive-label { color: var(--muted); font-size: .76rem; text-transform: uppercase; letter-spacing: .08em; }
      .exec-dashboard { display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 14px; }
      .exec-card { min-height: 132px; display: grid; align-content: space-between; gap: 12px; }
      .exec-card.primary { border-top: 3px solid var(--accent); }
      .exec-value { display: block; margin-top: 8px; font-size: 1.85rem; line-height: 1; font-weight: 850; letter-spacing: 0; overflow-wrap: anywhere; }
      .exec-note { color: var(--muted); font-size: .78rem; line-height: 1.3; }
      .severity-chart { display: grid; grid-template-columns: 1fr; gap: 10px; margin-bottom: 14px; }
      .severity-track { min-height: 18px; display: flex; overflow: hidden; border: 1px solid var(--border); border-radius: 999px; background: #020617; }
      .severity-segment { min-width: 0; width: 0%; transition: width .3s ease; }
      .severity-segment.critical { background: var(--critical); }
      .severity-segment.high { background: var(--high); }
      .severity-segment.medium { background: var(--medium); }
      .severity-segment.low { background: var(--low); }
      .severity-segment.info { background: var(--info); }
      .severity-legend { display: flex; flex-wrap: wrap; gap: 8px; }
      .legend-dot { width: .65rem; height: .65rem; border-radius: 999px; display: inline-block; }
      .finding-list { display: grid; gap: 12px; }
      .finding-card { border: 1px solid var(--border); border-left: 5px solid var(--info); border-radius: 8px; background: var(--panel); padding: 14px; display: grid; gap: 10px; box-shadow: 0 6px 16px rgba(15,23,42,.05); }
      .finding-card.critical { border-left-color: var(--critical); }
      .finding-card.high { border-left-color: var(--high); }
      .finding-card.medium { border-left-color: var(--medium); }
      .finding-card.low { border-left-color: var(--low); }
      .finding-head { display: flex; justify-content: space-between; gap: 12px; align-items: start; }
      .finding-title { font-weight: 800; font-size: 1rem; }
      .finding-grid { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 10px; }
      .finding-evidence { padding: 10px; border-radius: 8px; background: var(--panel-2); border: 1px solid var(--border); }
      .reference-list { margin: 0; padding-left: 18px; }
      .ranking-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 14px; margin-top: 16px; }
      .ranking-card { border: 1px solid var(--border); border-radius: 8px; background: var(--panel-2); padding: 14px; }
      .investigation-queue { display: grid; grid-template-columns: minmax(280px, 1.25fr) minmax(240px, .85fr); gap: 14px; margin-top: 16px; }
      .investigation-stack { display: grid; gap: 12px; }
      .investigation-card { border: 1px solid var(--border); border-radius: 8px; background: var(--panel-2); padding: 14px; display: grid; gap: 10px; }
      .investigation-card.primary { border-color: rgba(34,211,238,.44); background: linear-gradient(135deg, rgba(34,211,238,.10), var(--panel-2)); }
      .investigation-card.compact { gap: 8px; }
      .lead-target { font-size: 1.05rem; font-weight: 850; overflow-wrap: anywhere; }
      .action-line { border-left: 3px solid var(--accent); padding: 8px 10px; background: rgba(34,211,238,.07); color: var(--text); border-radius: 6px; }
      .details-lite { border: 1px solid var(--border); border-radius: 8px; background: rgba(15,23,42,.62); }
      .details-lite summary { cursor: pointer; padding: 8px 10px; color: var(--muted); font-weight: 700; }
      .details-lite > div { border-top: 1px solid var(--border); padding: 10px; }
      .ranking-list { list-style: none; margin: 10px 0 0; padding: 0; display: grid; gap: 8px; }
      .ranking-list li { display: flex; justify-content: space-between; gap: 10px; border-bottom: 1px solid var(--border); padding-bottom: 8px; }
      .ranking-list li:last-child { border-bottom: 0; padding-bottom: 0; }
      .rank-index { color: var(--muted); font-weight: 800; }
      .intel-card { padding: 22px; }
      .intel-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(145px, 1fr)); gap: 12px; margin-top: 14px; }
      .intel-item { border: 1px solid var(--border); border-radius: 8px; padding: 14px; background: var(--panel-2); }
      .intel-value { display: block; font-size: 1.55rem; font-weight: 850; line-height: 1.12; overflow-wrap: anywhere; word-break: break-word; }
      .intel-value.time-value { font-size: 1rem; line-height: 1.25; letter-spacing: 0; }
      .intel-label { display: block; margin-top: 7px; color: var(--muted); font-size: .82rem; }
      .intel-note { display: block; margin-top: 5px; color: var(--muted); font-size: .72rem; line-height: 1.25; }
      .intel-row { margin-top: 14px; display: grid; gap: 10px; }
      .status-card { border-left: 4px solid var(--warning); }
      .severity-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }
      .severity { position: relative; overflow: hidden; }
      .severity:before { content: ""; position: absolute; inset: 0 auto 0 0; width: 4px; background: var(--accent); }
      .severity.critical:before { background: var(--critical); }
      .severity.high:before { background: var(--high); }
      .severity.medium:before { background: var(--medium); }
      .severity.low:before { background: var(--low); }
      .severity.info:before { background: var(--info); }
      .data-panel { overflow: hidden; }
      .data-panel + .data-panel { margin-top: 14px; }
      .data-panel summary { cursor: pointer; list-style: none; padding: 18px; display: flex; justify-content: space-between; gap: 14px; align-items: center; }
      .data-panel summary::-webkit-details-marker { display: none; }
      .summary-title { display: flex; flex-direction: column; gap: 2px; }
      .summary-title strong { font-size: 1.05rem; }
      .summary-count { color: var(--accent); font-weight: 800; }
      .panel-body { border-top: 1px solid var(--border); padding: 16px 18px 18px; }
      .panel-tools { display: flex; flex-wrap: wrap; align-items: center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
      .search {
        width: min(420px, 100%);
        color: var(--text);
        background: var(--panel);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 10px 12px;
        outline: none;
      }
      .search:focus { border-color: var(--accent); box-shadow: 0 0 0 3px rgba(15,118,110,.13); }
      .category-row { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 14px; }
      .table-wrap { overflow: auto; border: 1px solid var(--border); border-radius: 8px; }
      table { width: 100%; border-collapse: collapse; min-width: 680px; }
      th, td { padding: 12px 14px; border-bottom: 1px solid var(--border); text-align: left; vertical-align: top; }
      th {
        position: sticky; top: 0; z-index: 1;
        background: #0f172a;
        color: var(--muted);
        font-size: .76rem;
        text-transform: uppercase;
        letter-spacing: .08em;
      }
      tr:hover td { background: rgba(15,118,110,.045); }
      tr:last-child td { border-bottom: 0; }
      .empty { min-height: 120px; display: grid; place-items: center; text-align: center; color: var(--muted); border: 1px dashed rgba(100, 116, 139, .35); border-radius: 8px; background: var(--panel-2); }
      .shot-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(230px, 1fr)); gap: 14px; }
      .shot-card { overflow: hidden; padding: 0; }
      .shot-card img { width: 100%; aspect-ratio: 16 / 10; object-fit: cover; display: block; background: #111827; border-bottom: 1px solid var(--border); cursor: zoom-in; }
      .shot-body { padding: 14px; }
      .shot-title { color: var(--text); font-weight: 700; font-size: .9rem; overflow-wrap: anywhere; }
      .failed-shot-list { display: grid; gap: 8px; margin-top: 14px; }
      .failed-shot { display: flex; justify-content: space-between; gap: 12px; align-items: center; border: 1px solid var(--border); border-radius: 8px; padding: 10px 12px; background: rgba(245,158,11,.10); }
      .lightbox { position: fixed; inset: 0; z-index: 20; display: none; align-items: center; justify-content: center; padding: 24px; background: rgba(15,23,42,.82); }
      .lightbox.open { display: flex; }
      .lightbox img { max-width: min(1200px, 96vw); max-height: 86vh; border-radius: 8px; box-shadow: 0 24px 70px rgba(0,0,0,.35); background: #111827; }
      .lightbox button { position: absolute; top: 16px; right: 16px; }
      .footer { margin-top: 28px; padding: 20px 0 6px; border-top: 1px solid var(--border); color: var(--muted); display: flex; justify-content: space-between; gap: 16px; flex-wrap: wrap; }
      .hidden { display: none !important; }
      @media (max-width: 1050px) {
        .layout { grid-template-columns: 1fr; }
        .sidebar { position: static; }
        .nav { grid-template-columns: repeat(auto-fit, minmax(120px, 1fr)); }
        .surface, .severity-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .exec-dashboard { grid-template-columns: repeat(2, minmax(0, 1fr)); }
        .hero { grid-template-columns: 1fr; }
        .investigation-queue { grid-template-columns: 1fr; }
        .meta-grid, .risk-panel { min-width: 0; }
      }
      @media (max-width: 620px) {
        .layout { width: min(100% - 24px, 1460px); padding-top: 14px; }
        .hero { padding: 18px; border-radius: 18px; }
        .kpis, .surface, .severity-grid, .intel-grid { grid-template-columns: 1fr 1fr; }
        .exec-dashboard { grid-template-columns: 1fr; }
        .meta-grid { grid-template-columns: 1fr; }
        .toolbar, .panel-tools { align-items: stretch; }
        .actions, .search { width: 100%; }
        .btn { flex: 1; text-align: center; }
        .data-panel summary { align-items: flex-start; flex-direction: column; }
        .hero-meta, .finding-head, .failed-shot { align-items: flex-start; flex-direction: column; }
        .risk-panel-grid, .finding-grid { grid-template-columns: 1fr; }
      }
      @media print {
        body { background: #ffffff; color: #111827; }
        .layout { display: block; width: 100%; padding: 0; }
        .sidebar, .toolbar, .panel-tools, .lightbox, .footer { display: none !important; }
        .hero, .card, .data-panel, .ranking-card, .intel-item { box-shadow: none; break-inside: avoid; page-break-inside: avoid; }
        .section { break-inside: avoid; page-break-inside: avoid; margin-bottom: 18px; }
        .table-wrap { overflow: visible; }
        a { color: #0369a1; }
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <aside class="sidebar" aria-label="Report navigation">
        <div class="side-brand">BladeRecon</div>
        <nav class="nav">
          <a href="#overview"><span class="nav-icon">&#8962;</span> Overview</a>
          <a href="#where-start"><span class="nav-icon">&#9733;</span> Start</a>
          <a href="#executive-summary"><span class="nav-icon">&#9632;</span> Summary</a>
          <a href="#top-investigation-campaigns"><span class="nav-icon">&#9670;</span> Campaigns</a>
          <a href="#additional-opportunities"><span class="nav-icon">?</span> More Leads</a>
          <a href="#subdomains"><span class="nav-icon">&#9711;</span> Subdomains</a>
          <a href="#javascript"><span class="nav-icon">{ }</span> JavaScript</a>
          <a href="#endpoints"><span class="nav-icon">&#8599;</span> Endpoints</a>
          <a href="#parameters"><span class="nav-icon">#</span> Parameters</a>
          <a href="#technology"><span class="nav-icon">T</span> Technology</a>
          <a href="#intelligence"><span class="nav-icon">R</span> Intelligence</a>
          <a href="#advanced-recon"><span class="nav-icon">+</span> Advanced</a>
          <a href="#secrets"><span class="nav-icon">&#9671;</span> Secrets</a>
          <a href="#screenshots"><span class="nav-icon">&#9638;</span> Screenshots</a>
          <a href="#findings"><span class="nav-icon">!</span> Findings</a>
          <a href="#performance"><span class="nav-icon">%</span> Performance</a>
        </nav>
      </aside>

      <main class="main">
        <header class="hero" id="overview">
          <div>
            <div class="brand"><span class="logo">{% if report_logo_data_uri %}<img src="{{ report_logo_data_uri }}" alt="BladeRecon report logo">{% else %}BR{% endif %}</span><span>BladeRecon</span></div>
            <h1>{{ target }}</h1>
            <p>Security assessment report with executive context, scan evidence, and raw data drill-downs.</p>
            <div class="hero-meta">
              <span class="hero-pill">Generated <strong>{{ timestamp }}</strong></span>
              <span class="hero-pill">Duration <strong>{{ scan_duration }}</strong></span>
              <span class="hero-pill">Profile <strong>{{ scan_profile }}</strong></span>
              <span class="hero-pill">Framework <strong>{{ framework_version }}</strong></span>
              <span class="hero-pill">Report <strong>v{{ report_version }}</strong></span>
            </div>
          </div>
          <aside class="risk-panel" aria-label="Risk summary">
            <div class="risk-score">
              <div>
                <div class="label">Research Opportunity Score</div>
                <strong>{{ research_opportunity_score.get("score", 0) }}</strong>
                <span class="muted">/100</span>
              </div>
              <span class="risk-level">{{ research_opportunity_score.get("level", "No Clear Lead") }}</span>
            </div>
            <div class="risk-panel-grid">
              <div class="risk-mini"><div class="label">Program Risk</div><div class="value">{% if risk_score %}{{ risk_score.get("score", 0) }}/100{% else %}0/100{% endif %}</div></div>
              <div class="risk-mini"><div class="label">Findings</div><div class="value">{{ nuclei_status }}</div></div>
              <div class="risk-mini"><div class="label">Alive Hosts</div><div class="value">{{ alive_count }}</div></div>
              <div class="risk-mini"><div class="label">Top Lead</div><div class="value">{{ research_opportunity_score.get("top_target", "None") or "None" }}</div></div>
            </div>
            <div class="note">Opportunity score ranks where to spend research time. Program risk summarizes broad exposure; it is not the same signal.</div>
          </aside>
        </header>

        <div class="toolbar">
          <div class="muted">Use the navigation and collapsed panels to inspect only what matters.</div>
          <div class="actions">
            <a class="btn" href="report.md">Export Markdown</a>
            <a class="btn" href="report.html" download>Export HTML</a>
            <button class="btn" id="copySummary" type="button">Copy Summary</button>
          </div>
        </div>

        <section class="section" id="executive-summary">
          <div class="section-head">
            <div>
              <h2>Executive Summary</h2>
              <small>Decision dashboard for scan outcome and next action</small>
            </div>
          </div>
          <div class="exec-dashboard">
            <div class="card exec-card primary">
              <div>
                <span class="label">Opportunity Level</span>
                <span class="exec-value">{{ research_opportunity_score.get("score", 0) }}/100</span>
              </div>
              <div class="exec-note">{{ research_opportunity_score.get("level", "No Clear Lead") }} - use the start-here queue before inventory.</div>
            </div>
            <div class="card exec-card">
              <div>
                <span class="label">Attack Surface</span>
                <span class="exec-value">{{ alive_count }}</span>
              </div>
              <div class="exec-note">{{ attack_surface.total_assets }} total assets, {{ endpoints | length }} endpoint{{ "" if endpoints | length == 1 else "s" }}, {{ js_files | length }} JS file{{ "" if js_files | length == 1 else "s" }}.</div>
            </div>
            <div class="card exec-card">
              <div>
                <span class="label">Nuclei Outcome</span>
                <span class="exec-value {% if nuclei_skipped_reason %}status-number{% endif %}">{% if nuclei_skipped_reason %}{{ nuclei_status_label }}{% else %}{{ nuclei_count }}{% endif %}</span>
              </div>
              <div class="exec-note">{% if nuclei_skipped_reason %}Skipped by ROI/runtime state. See details below.{% elif nuclei_count == 0 %}Completed with zero findings.{% else %}Finding count from executed templates.{% endif %}</div>
            </div>
            <div class="card exec-card">
              <div>
                <span class="label">Scan Outcome</span>
                <span class="exec-value">{{ scan_duration }}</span>
              </div>
              <div class="exec-note">{{ screenshots_status }} screenshots; {{ parameters_status }} parameters; Program Risk {% if risk_score %}{{ risk_score.get("score", 0) }}/100{% else %}not scored{% endif %}.</div>
            </div>
          </div>
        </section>

        {% if next_investigation_targets %}
        <section class="section card" id="where-start">
          <div class="section-head">
            <div>
              <h2>Where Should I Start?</h2>
              <small>The fastest path from recon data to manual bug bounty testing</small>
            </div>
          </div>
          <div class="investigation-queue">
            {% set lead = next_investigation_targets[0] %}
            <div class="investigation-card primary">
              <span class="label">Start here - score {{ lead.score | default(0) }}/100 - {{ lead.confidence | default("Low") }} confidence - {{ lead.validation_strength | default("None") }} validation</span>
              <div class="lead-target">{{ lead.target }}</div>
              <div><strong>Why investigate:</strong> {{ lead.reason }}</div>
              <div class="action-line"><strong>Test first:</strong> {{ lead.suggested_testing | default("Manual verification") }}</div>
              {% if lead.evidence_summary %}
              <div class="chips">
                {% for summary in lead.evidence_summary[:3] %}
                <span class="chip">{{ summary }}</span>
                {% endfor %}
              </div>
              {% endif %}
              <details class="details-lite">
                <summary>Evidence and validation details</summary>
                <div>
                  {% if lead.evidence %}
                  <ul class="ranking-list">
                    {% for evidence in lead.evidence[:3] %}
                    <li><span>{{ evidence.type }}{% if evidence.source %} via {{ evidence.source }}{% endif %}</span><strong>{{ evidence.value }}</strong></li>
                    {% endfor %}
                  </ul>
                  {% endif %}
                  {% if lead.positive_validation_signals %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for signal in lead.positive_validation_signals[:3] %}
                    <span class="chip">+ {{ signal }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                  {% if lead.negative_validation_signals %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for signal in lead.negative_validation_signals[:2] %}
                    <span class="chip">- {{ signal }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
              </details>
            </div>
            <div class="investigation-stack">
              {% for item in next_investigation_targets[1:4] %}
              <div class="investigation-card compact">
                <span class="label">Next option - score {{ item.score | default(0) }}/100 - {{ item.confidence | default("Low") }}</span>
                <div class="lead-target">{{ item.target }}</div>
                <small>{{ item.reason }}</small>
                <div class="note">Test first: {{ item.suggested_testing | default("Manual verification") }}</div>
              </div>
              {% endfor %}
            </div>
          </div>
        </section>
        {% elif no_actionable_surface %}
        <section class="section card" id="where-start">
          <div class="section-head">
            <div>
              <h2>Where Should I Start?</h2>
              <small>No actionable attack surface discovered</small>
            </div>
          </div>
          <div class="empty">
            BladeRecon did not find live hosts, endpoints, secrets, findings, or validated historical surface for this target. Treat this as a low-signal or unreachable scan rather than a bug-hunting lead.
          </div>
        </section>
        {% endif %}

        {% if investigation_campaigns %}
        <section class="section card" id="top-investigation-campaigns">
          <div class="section-head">
            <div>
              <h2>Top Investigation Campaigns</h2>
              <small>Attack-surface clusters that reduce triage and focus manual testing</small>
            </div>
          </div>
          <div class="ranking-grid">
            {% for item in investigation_campaigns[:5] %}
            <div class="ranking-card">
              <span class="label">{{ item.confidence | default("Low") }} confidence - {{ item.validation_strength | default("None") }} validation</span>
              <div class="value">{{ item.name }}</div>
              <div><strong>Why investigate:</strong> {{ item.priority_reason }}</div>
              <div class="action-line"><strong>Likely weakness:</strong> {{ item.likely_weakness | default("Access control or exposure weakness") }}</div>
              <div class="note" style="margin-top: 8px;"><strong>Test first:</strong> {{ item.suggested_testing_strategy }}</div>
              {% if item.merged_campaigns %}
              <div class="note" style="margin-top: 8px;"><strong>Merged related focus:</strong> {{ item.merged_campaigns[:4] | join("; ") }}</div>
              {% endif %}
              {% if item.top_targets %}
              <ul class="ranking-list" style="margin-top: 10px;">
                {% for target in item.top_targets[:4] %}
                <li><span>Target</span><strong>{{ target }}</strong></li>
                {% endfor %}
              </ul>
              {% endif %}
              <details class="details-lite" style="margin-top: 10px;">
                <summary>Supporting evidence, confidence, and validation</summary>
                <div>
                  <ul class="ranking-list" style="margin-bottom: 10px;">
                    <li><span>Opportunities</span><strong>{{ item.opportunity_count | default(0) }}</strong></li>
                    <li><span>Average confidence</span><strong>{{ item.average_confidence | default("Low") }}</strong></li>
                    <li><span>Evidence sources</span><strong>{{ item.evidence_diversity | default(0) }}</strong></li>
                  </ul>
                  {% if item.evidence_summary %}
                  <div class="chips">
                    {% for summary in item.evidence_summary[:3] %}
                    <span class="chip">{{ summary }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                  {% if item.positive_validation_signals %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for signal in item.positive_validation_signals[:3] %}
                    <span class="chip">+ {{ signal }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                  {% if item.negative_validation_signals %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for signal in item.negative_validation_signals[:2] %}
                    <span class="chip">- {{ signal }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
              </details>
            </div>
            {% endfor %}
          </div>
        </section>
        {% endif %}

        {% if next_investigation_targets %}
        <section class="section card" id="additional-opportunities">
          <div class="section-head">
            <div>
              <h2>Additional Opportunities</h2>
              <small>Secondary leads after the canonical start-here queue</small>
            </div>
          </div>
          {% if next_investigation_targets | length == 1 %}
          <div class="empty">The primary target is shown above in Where Should I Start?. No additional targets were prioritized.</div>
          {% else %}
          <div class="investigation-stack">
            {% for item in next_investigation_targets[1:6] %}
            <div class="investigation-card compact">
              <span class="label">{{ item.priority | default("Focused Review") }} - score {{ item.score | default(0) }}/100</span>
              <div class="lead-target">{{ item.target }}</div>
              <div><strong>Why investigate:</strong> {{ item.reason }}</div>
              <div class="action-line"><strong>Test first:</strong> {{ item.suggested_testing | default("Manual verification") }}</div>
              <details class="details-lite">
                <summary>Supporting evidence, confidence, and validation</summary>
                <div>
                  <ul class="ranking-list">
                    <li><span>Confidence</span><strong>{{ item.confidence | default("Low") }}</strong></li>
                    <li><span>Validation</span><strong>{{ item.validation_strength | default("None") }}</strong></li>
                    <li><span>Indicators</span><strong>{{ item.indicator_count | default(0) }}</strong></li>
                    <li><span>Evidence sources</span><strong>{{ item.evidence_diversity | default(0) }}</strong></li>
                    <li><span>Correlation</span><strong>{{ item.correlation_strength | default(0) }}</strong></li>
                  </ul>
                  {% if item.evidence_summary %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for summary in item.evidence_summary[:4] %}
                    <span class="chip">{{ summary }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                  {% if item.evidence %}
                  <ul class="ranking-list" style="margin-top: 10px;">
                    {% for evidence in item.evidence[:3] %}
                    <li><span>{{ evidence.type }} evidence{% if evidence.source %} via {{ evidence.source }}{% endif %}</span><strong>{{ evidence.value }}</strong></li>
                    {% endfor %}
                  </ul>
                  {% endif %}
                  {% if item.positive_validation_signals %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for signal in item.positive_validation_signals[:3] %}
                    <span class="chip">+ {{ signal }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                  {% if item.negative_validation_signals %}
                  <div class="chips" style="margin-top: 10px;">
                    {% for signal in item.negative_validation_signals[:2] %}
                    <span class="chip">- {{ signal }}</span>
                    {% endfor %}
                  </div>
                  {% endif %}
                </div>
              </details>
            </div>
            {% endfor %}
          </div>
          {% endif %}
        </section>
        {% endif %}

        <section class="section card summary-card">
          <div class="section-head">
            <h2>Attack Surface Summary</h2>
            <small>Generated by BladeRecon</small>
          </div>
          <ul>
            <li><strong>{{ subdomains | length }}</strong> subdomains discovered.</li>
            <li><strong>{{ alive_count }}</strong> alive hosts detected.</li>
            <li><strong>{{ js_files | length }}</strong> JavaScript assets identified.</li>
            <li><strong>{{ endpoints | length }}</strong> endpoint candidates extracted.</li>
            <li>{% if parameters_skipped_reason %}Parameters: <strong>Skipped</strong> ({{ parameters_skipped_reason }}).{% else %}<strong>{{ parameter_intelligence.total_count }}</strong> parameters identified: {{ parameter_intelligence.discovered_count }} discovered, {{ parameter_intelligence.candidate_count }} candidates.{% endif %}</li>
            <li>{% if secrets %}<strong>{{ secrets | length }}</strong> exposed secret pattern matches detected.{% else %}No exposed secrets detected.{% endif %}</li>
            <li>{% if nuclei_skipped_reason %}Nuclei: <strong>{{ nuclei_status_label }}</strong> ({{ nuclei_skipped_reason }}).{% elif nuclei_available %}<strong>{{ nuclei_count }}</strong> Nuclei findings available.{% else %}No Nuclei findings available.{% endif %}</li>
            {% if advanced_metadata %}<li><strong>{{ historical_urls | length }}</strong> historical URLs, <strong>{{ content_discovery | length }}</strong> interesting paths, and <strong>{{ asset_priority.get("asset_count", 0) }}</strong> priority assets added by advanced recon.</li>{% endif %}
          </ul>
        </section>

        <section class="section card intel-card">
          <div class="section-head">
            <div>
              <h2>Attack Surface Overview</h2>
              <small>Signal-first intelligence summary</small>
            </div>
          </div>
          <div class="intel-grid">
            <div class="intel-item"><span class="intel-value">{{ attack_surface.total_assets }}</span><span class="intel-label">Assets</span></div>
            <div class="intel-item"><span class="intel-value">{{ attack_surface.alive_assets }}</span><span class="intel-label">Alive</span></div>
            <div class="intel-item"><span class="intel-value">{{ js_files | length }}</span><span class="intel-label">JS Assets</span></div>
            <div class="intel-item"><span class="intel-value">{{ endpoints | length }}</span><span class="intel-label">Endpoints</span></div>
            <div class="intel-item"><span class="intel-value {% if parameters_skipped_reason %}status-number{% endif %}">{% if parameters_skipped_reason %}Skipped{% else %}{{ parameters | length }}{% endif %}</span><span class="intel-label">Parameters</span></div>
            <div class="intel-item"><span class="intel-value">{% if attack_surface.total_assets %}{{ ((attack_surface.alive_assets / attack_surface.total_assets) * 100) | round(1) }}%{% else %}0%{% endif %}</span><span class="intel-label">Coverage</span></div>
          </div>
          <div class="intel-row">
            <div><span class="label">Technology Stack</span><div class="chips">{% for item in attack_surface.technology_stack %}<span class="chip">{{ item }}</span>{% else %}<span class="muted">No technologies identified</span>{% endfor %}</div></div>
            <div><span class="label">WAF</span> {% if attack_surface.waf_detected %}<span class="badge high">Detected</span>{% else %}<span class="badge passive">Not Detected</span>{% endif %}</div>
          </div>
        </section>

        <section class="section card" id="technology">
          <div class="section-head">
            <h2>Technology Overview</h2>
            <small>Technologies Detected: {{ attack_surface.technology_count }}</small>
          </div>
          {% if attack_surface.technologies or attack_surface.cdn_detected or attack_surface.waf_detected or attack_surface.servers %}
          <div class="section-head" style="margin-top: 10px;">
            <h3>Attack-Surface Technologies</h3>
            <small>Technologies more likely to guide manual testing</small>
          </div>
          {% if attack_surface.attack_surface_technologies %}
          <div class="chips">
            {% for item in attack_surface.attack_surface_technologies %}
            <span class="chip">{{ item.name }}{% if item.roles %}: {{ item.roles | join(" / ") }}{% endif %}</span>
            {% endfor %}
          </div>
          {% else %}
          <div class="empty">No attack-surface technologies were confidently identified. Infrastructure detections are kept below as supporting context.</div>
          {% endif %}
          {% if attack_surface.infrastructure_technologies %}
          <details class="details-lite" style="margin-top: 14px;">
            <summary>Supporting infrastructure technologies</summary>
            <div class="chips" style="margin-top: 10px;">
              {% for item in attack_surface.infrastructure_technologies %}
              <span class="chip">{{ item.name }}{% if item.roles %}: {{ item.roles | join(" / ") }}{% endif %}</span>
              {% endfor %}
            </div>
          </details>
          {% endif %}
          {% if attack_surface.most_common_technologies %}
          <div class="section-head" style="margin-top: 10px;">
            <h3>Most Common Technologies</h3>
            <small>Observed across probed hosts</small>
          </div>
          <div class="chips">
            {% for item in attack_surface.most_common_technologies %}
            <span class="chip">{{ item[0] }}: {{ item[1] }}</span>
            {% endfor %}
          </div>
          {% endif %}
          {% if attack_surface.technology_categories %}
          <div class="section-head" style="margin-top: 18px;">
            <h3>Technology Categories</h3>
            <small>Normalized from headers, CDN, WAF, and HTML fingerprints</small>
          </div>
          {% if attack_surface.technology_roles %}
          <div class="section-head" style="margin-top: 12px;">
            <h3>Technology Roles</h3>
            <small>Unique products with observed roles</small>
          </div>
          <div class="chips" style="margin-bottom: 14px;">
            {% for tech, roles in attack_surface.technology_roles.items() %}
            <span class="chip">{{ tech }}: {{ roles | join(" / ") }}</span>
            {% endfor %}
          </div>
          {% endif %}
          <div class="intel-row">
            {% for category, values in attack_surface.technology_categories.items() %}
            <div class="intel-item">
              <span class="label">{{ category }}</span>
              <div class="chips" style="margin-top: 8px;">{% for item in values %}<span class="chip">{{ item }}</span>{% endfor %}</div>
            </div>
            {% endfor %}
          </div>
          {% endif %}
          {% if attack_surface.technology_details %}
          <details class="data-panel" style="margin-top: 18px;">
            <summary><span class="summary-title"><strong>Technology Evidence</strong><small>Confidence and source tracking for normalized detections</small></span><span class="summary-count">{{ attack_surface.technology_details | length }}</span></summary>
            <div class="panel-body">
          <div class="table-wrap">
            <table>
              <thead><tr><th>Technology</th><th>Confidence</th><th>Sources</th><th>Evidence</th><th>Hosts</th></tr></thead>
              <tbody>
                {% for item in attack_surface.technology_details %}
                <tr>
                  <td>{{ item.name }}</td>
                  <td><span class="badge {% if item.confidence == 'High' %}low{% elif item.confidence == 'Medium' %}medium{% else %}info{% endif %}">{{ item.confidence }}</span></td>
                  <td>{{ item.sources | join(", ") if item.sources else "Not recorded" }}</td>
                  <td>{{ item.evidence[:2] | join("; ") if item.evidence else "Not recorded" }}</td>
                  <td>{{ item.hosts[:3] | join(", ") if item.hosts else "Not recorded" }}</td>
                </tr>
                {% endfor %}
              </tbody>
            </table>
          </div>
            </div>
          </details>
          {% endif %}
          {% else %}
          <div class="empty">No technologies identified</div>
          {% endif %}
        </section>

        <section class="section card" id="intelligence">
          <div class="section-head">
            <h2>Recon Intelligence</h2>
            <small>Risk, infrastructure, cloud, and smart scanning context</small>
          </div>
          <div class="grid intel-grid">
            <div class="intel-item"><span class="intel-value">{% if risk_score %}{{ risk_score.get("score", 0) }}/100{% else %}Not Run{% endif %}</span><span class="intel-label">Risk Score{% if risk_score %} ({{ risk_score.get("level", "Not classified") }}){% endif %}</span></div>
            <div class="intel-item"><span class="intel-value">{{ infrastructure.get("assets", []) | length }}</span><span class="intel-label">Infrastructure Assets</span></div>
            <div class="intel-item"><span class="intel-value">{{ cloud_assets | length }}</span><span class="intel-label">Cloud Assets</span></div>
            <div class="intel-item"><span class="intel-value">{{ historical_dns.get("historical_hosts", []) | length }}</span><span class="intel-label">Historical Hosts</span></div>
          </div>
          {% if risk_score and risk_score.get("factors") %}
          <div class="chips" style="margin-top: 14px;">
            {% for factor in risk_score.get("factors", []) %}
            <span class="chip">{{ factor }}</span>
            {% endfor %}
          </div>
          {% endif %}
          {% if infrastructure.get("assets") %}
          <div class="section-head" style="margin-top: 18px;"><h3>Infrastructure Intelligence</h3><small>Resolved hosts and provider hints</small></div>
          <div class="chips">
            {% for asset in infrastructure.get("assets", [])[:10] %}
            <span class="chip">{{ asset.get("host", "") }}{% if asset.get("ip") %} -> {{ asset.get("ip") }}{% endif %}</span>
            {% endfor %}
          </div>
          {% endif %}
          {% if cloud_assets %}
          <div class="section-head" style="margin-top: 18px;"><h3>Cloud Assets</h3><small>References found in scan artifacts</small></div>
          <div class="chips">
            {% for asset in cloud_assets[:12] %}
            <span class="chip">{{ asset.get("type") }}: {{ asset.get("value") }}</span>
            {% endfor %}
          </div>
          {% endif %}
          {% if template_intelligence %}
          <div class="section-head" style="margin-top: 18px;"><h3>Smart Nuclei Summary</h3><small>{{ template_intelligence.get("templates_available", "Not Run") }} templates available</small></div>
          <div class="chips">
            {% for tag in template_intelligence.get("selected_tags", []) %}
            <span class="chip">{{ tag }}</span>
            {% endfor %}
          </div>
          {% endif %}
        </section>

        <section class="section card" id="advanced-recon">
          <div class="section-head">
            <div>
              <h2>Advanced Recon Intelligence</h2>
              <small>Historical coverage, targeted discovery, security-header assets, and priority ranking</small>
            </div>
          </div>
          <div class="intel-grid">
            <div class="intel-item"><span class="intel-value">{{ historical_urls | length }}</span><span class="intel-label">Historical URLs</span></div>
            <div class="intel-item"><span class="intel-value">{{ historical_endpoints | length }}</span><span class="intel-label">Historical Endpoints</span></div>
            <div class="intel-item"><span class="intel-value">{{ historical_diff.get("removed_apis", []) | length }}</span><span class="intel-label">Removed APIs</span></div>
            <div class="intel-item"><span class="intel-value">{{ content_discovery | length }}</span><span class="intel-label">Interesting Paths</span></div>
            <div class="intel-item"><span class="intel-value">{{ security_header_assets.get("assets", []) | length }}</span><span class="intel-label">Header Assets</span></div>
            <div class="intel-item"><span class="intel-value">{{ historical_js.get("endpoints", []) | length }}</span><span class="intel-label">Historical JS Endpoints</span></div>
          </div>
          {% if asset_priority.get("top_assets") %}
          <div class="section-head" style="margin-top: 18px;"><h3>Supporting Priority Asset Inventory</h3><small>Reference data behind the start-here queue</small></div>
          <div class="note" style="margin-bottom: 12px;">These assets support the recommendation queue above; they are not a separate priority system.</div>
          <div class="ranking-grid">
            {% for item in asset_priority.get("top_assets", [])[:6] %}
            <div class="ranking-card">
              <span class="label">Score {{ item.score }}/100 - {{ item.confidence | default("Medium") }} confidence</span>
              <div class="value">{{ item.asset }}</div>
              <small>{{ item.reasons[:3] | join(", ") }}</small>
              {% if item.strongest_factors %}
              <ul class="ranking-list" style="margin-top: 10px;">
                {% for factor in item.strongest_factors[:3] %}
                <li><span>{{ factor.reason }}</span><strong>+{{ factor.points }}</strong></li>
                {% endfor %}
              </ul>
              {% endif %}
            </div>
            {% endfor %}
          </div>
          {% endif %}
          {% if next_investigation_targets %}
          <div class="note" style="margin-top: 18px;">Top investigation targets are surfaced near the beginning of the report in Where Should I Start? Advanced Recon below keeps supporting inventory and source-quality details.</div>
          {% endif %}
          <details class="data-panel" style="margin-top: 18px;">
            <summary><span class="summary-title"><strong>Advanced Recon Details</strong><small>Historical diffs, header assets, paths, and historical JS findings</small></span><span class="summary-count">{{ advanced_metadata.get("requests_sent", 0) }} requests</span></summary>
            <div class="panel-body">
              <div class="ranking-grid">
                <div class="ranking-card">
                  <span class="label">Historical Attack Surface</span>
                  <ul class="ranking-list">
                    <li><span>Legacy paths</span><strong>{{ historical_diff.get("legacy_paths", []) | length }}</strong></li>
                    <li><span>Deprecated endpoints</span><strong>{{ historical_diff.get("deprecated_endpoints", []) | length }}</strong></li>
                    <li><span>Historical + alive</span><strong>{{ historical_diff.get("historical_and_currently_alive", []) | length }}</strong></li>
                    <li><span>Historical only</span><strong>{{ historical_diff.get("historical_only", []) | length }}</strong></li>
                    <li><span>Unresolved historical</span><strong>{{ historical_diff.get("historical_unresolved", []) | length }}</strong></li>
                  </ul>
                </div>
                <div class="ranking-card">
                  <span class="label">Quality Controls</span>
                  <ul class="ranking-list">
                    <li><span>Content SNR</span><strong>{{ advanced_metadata.get("content_discovery", {}).get("signal_to_noise_ratio", 0) }}</strong></li>
                    <li><span>Historical JS SNR</span><strong>{{ advanced_metadata.get("historical_js", {}).get("signal_to_noise_ratio", 0) }}</strong></li>
                    <li><span>Profile</span><strong>{{ scan_profile }}</strong></li>
                  </ul>
                </div>
              </div>
              {% if content_discovery %}
